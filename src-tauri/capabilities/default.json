{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "FinEx POS default capabilities",
  "windows": ["*"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:window:allow-close",
    "core:window:allow-set-title",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "https://finex.app.mn/**" }
      ]
    },
    "fs:default",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "fs:allow-exists",
    "fs:allow-mkdir",
    "shell:default",
    "shell:allow-open",
    "sql:default",
    "sql:allow-load",
    "sql:allow-execute",
    "sql:allow-select",
    "sql:allow-close",
    "updater:default",
    "updater:allow-check",
    "updater:allow-download-and-install",
    "process:default",
    "process:allow-exit",
    "process:allow-restart"
  ]
}
