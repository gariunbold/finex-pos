{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Finex POS",
  "version": "0.2.5",
  "identifier": "com.finex.pos",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:3001",
    "frontendDist": "../out"
  },
  "app": {
    "windows": [
      {
        "title": "Finex POS",
        "url": "login",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": "v1Compatible",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/gariunbold/finex-pos/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDM0RkNCNjRDNjg1QTQyN0MKUldSOFFscG9UTGI4Tk5BcTdtWk5iUTJpUzdST1NqaW1XVUJzcytYQTd2VUt5LzkxWTBaS3lTQ1IK"
    }
  }
}
